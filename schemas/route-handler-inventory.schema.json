{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://oceanleo.com/schemas/route-handler-inventory.v1.json",
  "title": "OceanLeo route and handler inventory",
  "definitions": {
    "capability": {
      "enum": [
        "shell:render",
        "artifact:read",
        "artifact:write",
        "workspace:session",
        "workbench:advanced",
        "browser:cloud",
        "website:launch",
        "website:source-edit",
        "website:deploy",
        "website:domain-admin",
        "website:vault",
        "website:server-admin",
        "website:provider-oauth"
      ]
    },
    "evidencePath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+$"
    },
    "method": {
      "enum": [
        "GET",
        "HEAD",
        "POST",
        "PUT",
        "PATCH",
        "DELETE",
        "OPTIONS",
        "*"
      ]
    },
    "routePattern": {
      "type": "string",
      "pattern": "^(?:/|/:[A-Za-z][A-Za-z0-9_]*\\*|/(?:[A-Za-z0-9._~-]+|:[A-Za-z][A-Za-z0-9_]*)(?:/(?:[A-Za-z0-9._~-]+|:[A-Za-z][A-Za-z0-9_]*))*(?:/:[A-Za-z][A-Za-z0-9_]*\\*)?)$"
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["schema", "sourceRevision", "summary", "entries"],
  "properties": {
    "schema": {
      "const": "oceanleo.route-handler-inventory.v1"
    },
    "sourceRevision": {
      "const": "terminal-acceptance-2026-07-21.3"
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tenants",
        "standardTenants",
        "privilegedTenants",
        "domains",
        "entries",
        "parity"
      ],
      "properties": {
        "tenants": { "const": 31 },
        "standardTenants": { "const": 30 },
        "privilegedTenants": { "const": 1 },
        "domains": { "const": 37 },
        "entries": { "type": "integer", "minimum": 1 },
        "parity": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "foundation",
            "pending",
            "partial",
            "verified",
            "retired"
          ],
          "properties": {
            "foundation": { "type": "integer", "minimum": 0 },
            "pending": { "type": "integer", "minimum": 0 },
            "partial": { "type": "integer", "minimum": 0 },
            "verified": { "type": "integer", "minimum": 0 },
            "retired": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "appProfile",
          "tenantKey",
          "route",
          "kind",
          "methods",
          "capabilities",
          "extensionId",
          "migrationBatch",
          "parity"
        ],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "appProfile": {
            "enum": ["standard", "website-privileged"]
          },
          "tenantKey": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "route": {
            "oneOf": [
              { "$ref": "#/definitions/routePattern" },
              { "type": "null" }
            ]
          },
          "kind": {
            "enum": [
              "page",
              "route-handler",
              "metadata",
              "plugin-extension"
            ]
          },
          "methods": {
            "type": "array",
            "items": { "$ref": "#/definitions/method" },
            "uniqueItems": true
          },
          "capabilities": {
            "type": "array",
            "items": { "$ref": "#/definitions/capability" },
            "uniqueItems": true
          },
          "extensionId": {
            "type": ["string", "null"]
          },
          "migrationBatch": {
            "type": "integer",
            "minimum": 1,
            "maximum": 6
          },
          "parity": {
            "type": "object",
            "additionalProperties": false,
            "required": ["status", "source", "evidence"],
            "properties": {
              "status": {
                "enum": [
                  "foundation",
                  "pending",
                  "partial",
                  "verified",
                  "retired"
                ]
              },
              "source": { "type": "string", "minLength": 1 },
              "evidence": {
                "type": "array",
                "items": { "$ref": "#/definitions/evidencePath" },
                "uniqueItems": true
              }
            }
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": { "const": "plugin-extension" }
              },
              "required": ["kind"]
            },
            "then": {
              "properties": {
                "route": { "type": "null" },
                "extensionId": { "type": "string", "minLength": 1 },
                "methods": { "type": "array", "maxItems": 0 }
              }
            },
            "else": {
              "properties": {
                "route": { "$ref": "#/definitions/routePattern" },
                "methods": { "type": "array", "minItems": 1 }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": { "const": "metadata" }
              },
              "required": ["kind"]
            },
            "then": {
              "properties": {
                "extensionId": { "type": "null" }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": { "const": "page" }
              },
              "required": ["kind"]
            },
            "then": {
              "properties": {
                "methods": {
                  "type": "array",
                  "items": { "enum": ["GET", "HEAD"] },
                  "contains": { "const": "GET" }
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": { "enum": ["page", "route-handler"] },
                "parity": {
                  "type": "object",
                  "properties": {
                    "status": { "const": "foundation" }
                  },
                  "required": ["status"]
                }
              },
              "required": ["kind", "parity"]
            },
            "then": {
              "properties": {
                "extensionId": { "type": "null" }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": { "enum": ["page", "route-handler"] },
                "parity": {
                  "type": "object",
                  "properties": {
                    "status": {
                      "enum": ["pending", "partial", "verified", "retired"]
                    }
                  },
                  "required": ["status"]
                }
              },
              "required": ["kind", "parity"]
            },
            "then": {
              "properties": {
                "extensionId": { "type": "string", "minLength": 1 }
              }
            }
          },
          {
            "if": {
              "properties": {
                "parity": {
                  "type": "object",
                  "properties": {
                    "status": { "enum": ["verified", "retired"] }
                  },
                  "required": ["status"]
                }
              },
              "required": ["parity"]
            },
            "then": {
              "properties": {
                "parity": {
                  "type": "object",
                  "properties": {
                    "evidence": { "type": "array", "minItems": 1 }
                  }
                }
              }
            }
          }
        ]
      }
    }
  }
}

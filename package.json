{
  "name": "oceanleo-sites",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build:standard": "pnpm --filter @oceanleo/standard-app build",
    "build:website-privileged": "pnpm --filter @oceanleo/website-privileged-app build",
    "cutover": "tsx scripts/cutover-controller.ts",
    "cutover:check": "tsx scripts/cutover-controller.ts check",
    "cutover:create-project": "tsx scripts/cutover-controller.ts create-project",
    "cutover:deploy": "tsx scripts/cutover-controller.ts deploy",
    "cutover:move": "tsx scripts/cutover-controller.ts move",
    "cutover:plan": "tsx scripts/cutover-controller.ts plan --sha \"$(git rev-parse HEAD)\"",
    "cutover:review": "tsx scripts/cutover-review.ts",
    "cutover:rollback": "tsx scripts/cutover-controller.ts rollback",
    "cutover:source-sha": "git rev-parse HEAD",
    "cutover:status": "tsx scripts/cutover-controller.ts status",
    "cutover:sync-env": "tsx scripts/cutover-controller.ts sync-env",
    "retirement": "tsx scripts/retirement-controller.ts",
    "retirement:status": "tsx scripts/retirement-controller.ts status",
    "retirement:check": "tsx scripts/retirement-controller.ts check",
    "retirement:seal-r0": "tsx scripts/retirement-seal-r0.ts",
    "retirement:soak-probe": "tsx scripts/retirement-soak-probe.ts",
    "retirement:refresh-ops": "tsx scripts/retirement-refresh-ops-receipts.ts",
    "inventory:generate": "tsx scripts/generate-inventory.ts",
    "inventory:check": "tsx scripts/check-inventory.ts",
    "test": "node --conditions=react-server --import tsx --test tests/*.test.ts && pnpm -r --filter './packages/**' --if-present run test",
    "test:cutover": "node --import tsx --test tests/cutover-*.test.ts",
    "typecheck": "pnpm typecheck:tools && pnpm -r --if-present typecheck",
    "typecheck:cutover": "tsc -p deploy/tsconfig.json",
    "typecheck:tools": "tsc -p tsconfig.tools.json",
    "check": "pnpm inventory:check && pnpm test && pnpm typecheck",
    "retirement:accelerate-reseal": "tsx scripts/retirement-accelerate-reseal.ts"
  },
  "devDependencies": {
    "@oceanleo/capabilities": "workspace:*",
    "@oceanleo/plugin-registry": "workspace:*",
    "@oceanleo/plugin-runtime": "workspace:*",
    "@oceanleo/runtime": "workspace:*",
    "@oceanleo/tenant-registry": "workspace:*",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "ajv": "^8.20.0",
    "next": "^16.2.10",
    "next-intl": "^4.13.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "server-only": "^0.0.1",
    "tsx": "^4.23.1",
    "typescript": "~5.9.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz"
  }
}
